{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A task in the event checklist",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "completed": { "type": "boolean" },
        "category": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "completed", "category"]
    }
  },
  "firestore": {
    "tasks": {
      "schema": "Task",
      "description": "Collection of tasks for the event"
    }
  }
}
