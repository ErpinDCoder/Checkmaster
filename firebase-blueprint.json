{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A task in the event checklist",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "completed": { "type": "boolean" },
        "category": { "type": "string" },
        "notes": { "type": "string" },
        "eventId": { "type": "string" },
        "uid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "completed", "category", "eventId", "uid"]
    },
    "Event": {
      "title": "Event",
      "description": "An event or checklist container",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "ownerName": { "type": "string" },
        "ownerEmail": { "type": "string" },
        "members": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "ownerName", "ownerEmail", "members"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message in the event chat",
      "type": "object",
      "properties": {
        "eventId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "fileUrl": { "type": "string" },
        "fileName": { "type": "string" },
        "fileType": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["eventId", "senderId", "senderName", "createdAt"]
    }
  },
  "firestore": {
    "tasks": {
      "schema": "Task",
      "description": "Collection of tasks for all events"
    },
    "events": {
      "schema": "Event",
      "description": "Collection of events"
    },
    "messages": {
      "schema": "ChatMessage",
      "description": "Collection of chat messages for events"
    }
  }
}
