// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: events
// Fields:
//   - name: string
//   - ownerId: string
//   - ownerName: string
//   - ownerEmail: string
//   - members: map (uid -> role)
//   - nicknames: map (uid -> string)
//   - ownerColor: string (hex)
//   - memberColor: string (hex)
//
// Collection: tasks
// Fields:
//   - text: string
//   - completed: boolean
//   - category: string
//   - notes: string
//   - eventId: string
//   - uid: string
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isEventMember(eventId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/events/$(eventId)) &&
        (
          get(/databases/$(database)/documents/events/$(eventId)).data.members[request.auth.uid] == 'owner' ||
          get(/databases/$(database)/documents/events/$(eventId)).data.members[request.auth.uid] == 'member'
        );
    }

    function isEventOwner(eventId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/events/$(eventId)) &&
        get(/databases/$(database)/documents/events/$(eventId)).data.members[request.auth.uid] == 'owner';
    }

    match /events/{eventId} {
      // Allow get for any authenticated user (needed for joining)
      // Allow list only for members
      allow get: if isAuthenticated();
      allow list: if isAuthenticated() && (
        resource.data.members[request.auth.uid] == 'owner' ||
        resource.data.members[request.auth.uid] == 'member'
      );
      
      allow create: if isAuthenticated() && 
                    request.resource.data.ownerId == request.auth.uid &&
                    request.resource.data.members[request.auth.uid] == 'owner';
      allow update: if isAuthenticated() && (
        // Owner can update everything
        resource.data.members[request.auth.uid] == 'owner' ||
        
        // Member or Joiner updating their own info
        (
          // Must be a member (or becoming one)
          (request.resource.data.members[request.auth.uid] == 'member' || resource.data.members[request.auth.uid] == 'member') &&
          // Cannot downgrade owner (owner has their own rule)
          resource.data.get('members', {})[request.auth.uid] != 'owner' &&
          // Only allowed to touch these top-level fields
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'nicknames', 'lastReadAt', 'updatedAt']) &&
          // Ensure they only touch their own keys in the maps
          (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['members']) ||
            request.resource.data.members.diff(resource.data.members).affectedKeys().hasOnly([request.auth.uid])
          ) &&
          (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['nicknames']) ||
            request.resource.data.get('nicknames', {}).diff(resource.data.get('nicknames', {})).affectedKeys().hasOnly([request.auth.uid])
          ) &&
          (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['lastReadAt']) ||
            request.resource.data.get('lastReadAt', {}).diff(resource.data.get('lastReadAt', {})).affectedKeys().hasOnly([request.auth.uid])
          )
        )
      );
      allow delete: if isAuthenticated() && resource.data.members[request.auth.uid] == 'owner';
    }
    
    match /messages/{messageId} {
      allow read: if isAuthenticated() && isEventMember(resource.data.eventId);
      allow create: if isAuthenticated() && 
                    isEventMember(request.resource.data.eventId) && 
                    request.resource.data.senderId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.senderId == request.auth.uid;
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated() && isEventMember(resource.data.eventId);
      allow create: if isAuthenticated() && isEventMember(request.resource.data.eventId);
      allow update: if isAuthenticated() && isEventMember(resource.data.eventId);
      allow delete: if isAuthenticated() && isEventMember(resource.data.eventId);
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
