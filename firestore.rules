// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: tasks
// Document ID: auto-generated
// Fields:
//   - text: string (required) - The task description
//   - completed: boolean (required) - Completion status
//   - category: string (required) - Task category
//   - notes: string (optional) - Detailed notes
//   - uid: string (required) - Creator's user ID
//   - createdAt: timestamp (required) - Creation time
//   - updatedAt: timestamp (required) - Last update time
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function isValidTask(data) {
      return data.text is string && data.text.size() > 0 && data.text.size() < 500 &&
             data.completed is bool &&
             data.category is string && data.category.size() > 0 && data.category.size() < 100 &&
             (!('notes' in data) || (data.notes is string && data.notes.size() < 2000)) &&
             data.uid is string && data.uid == request.auth.uid;
    }

    match /tasks/{taskId} {
      // Anyone authenticated can read all tasks for real-time collaboration
      allow read: if isAuthenticated();
      
      // Anyone authenticated can create a task
      allow create: if isAuthenticated() && isValidTask(request.resource.data) && uidUnchanged();
      
      // Anyone authenticated can update a task (for collaboration)
      // In a real app, we might restrict this more, but for a shared checklist, everyone can edit.
      allow update: if isAuthenticated() && 
                    // Basic validation
                    request.resource.data.text is string && 
                    request.resource.data.completed is bool &&
                    request.resource.data.category is string &&
                    (!('notes' in request.resource.data) || request.resource.data.notes is string) &&
                    // Ensure uid is not changed
                    uidNotModified();
      
      // Only the owner or an admin can delete
      allow delete: if isAuthenticated() && (isDocOwner() || request.auth.token.email == "ervinchandrawan17@gmail.com");
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
